{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and currency",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "choco": { "type": "number" },
        "goldenChoco": { "type": "number" },
        "checkInStreak": { "type": "number" },
        "lastCheckInDate": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "unlockedAchievements": { "type": "array" },
        "claimedAchievements": { "type": "array" },
        "totalEarnedChoco": { "type": "number" },
        "totalEarnedGChoco": { "type": "number" },
        "totalSpentChoco": { "type": "number" },
        "totalCheckIns": { "type": "number" },
        "perfectDailyDates": { "type": "array" },
        "sentMessagesCount": { "type": "number" },
        "genresRead": { "type": "array" },
        "activePoints": { "type": "number" },
        "lastActiveWeek": { "type": "string" },
        "prevActivePoints": { "type": "number" },
        "prevActiveWeek": { "type": "string" },
        "equippedStickerAvatar": { "type": "string" },
        "stickerPositionAvatar": { "type": "string" },
        "equippedStickerChat": { "type": "string" },
        "equippedStickerPost": { "type": "string" },
        "stickerPositionPost": { "type": "string" },
        "ownedStickers": { "type": "array" },
        "equippedAccessory": { "type": "string" },
        "accessoryPosition": { "type": "object" },
        "ownedAccessories": { "type": "array" }
      },
      "required": ["uid", "choco", "goldenChoco", "createdAt"]
    },
    "Story": {
      "title": "Story",
      "description": "Story metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "coverUrl": { "type": "string" },
        "genres": { "type": "array" },
        "chapterCount": { "type": "number" },
        "recommendations": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "author", "createdAt"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "Story chapter",
      "type": "object",
      "properties": {
        "storyId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "number" },
        "isPasswordProtected": { "type": "boolean" }
      },
      "required": ["storyId", "title", "content", "order"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Global chat message",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "displayName", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a story or chapter",
      "type": "object",
      "properties": {
        "targetId": { "type": "string" },
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["targetId", "uid", "content", "type", "createdAt"]
    },
    "UserTask": {
      "title": "User Task Progress",
      "description": "Tracks daily/weekly reading and checking in",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string" },
        "chaptersRead": { "type": "number" },
        "commentsMade": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "date", "updatedAt"]
    },
    "AvatarSticker": {
      "title": "AvatarSticker",
      "description": "Avatar sticker item for purchase in store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "description", "price", "type", "url"]
    },
    "AvatarAccessory": {
      "title": "AvatarAccessory",
      "description": "Avatar accessory item for purchase in store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "description", "price", "type", "url"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification for new audiobook/story chapters",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "storyId": { "type": "string" },
        "chapterId": { "type": "string" },
        "storyTitle": { "type": "string" },
        "chapterTitle": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "storyId", "chapterId", "storyTitle", "chapterTitle", "isRead", "createdAt"]
    },
    "NewsFeedPost": {
      "title": "News Feed Post",
      "description": "User uploaded status / post on profile that appears on global news feed",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "activeTitle": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "displayName", "content", "createdAt"]
    },
    "RadioTrack": {
      "title": "Choco Radio Track",
      "description": "Tracks and audio stream links for Choco Radio",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "streamUrl": { "type": "string" },
        "isSpotify": { "type": "boolean" },
        "spotifyEmbedUrl": { "type": "string" },
        "isLocalFile": { "type": "boolean" }
      },
      "required": ["title", "streamUrl"]
    },
    "GachaBanner": {
      "title": "Gacha Banner",
      "description": "Configuration for permanent and promotional limited banners",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string" },
        "active": { "type": "boolean" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "featured5Star": { "type": "object" },
        "featured4Stars": { "type": "array" },
        "pool5Star": { "type": "array" },
        "pool4Star": { "type": "array" },
        "pool3Star": { "type": "array" }
      },
      "required": ["name", "type", "active"]
    },
    "ExamScore": {
      "title": "Exam Score",
      "description": "User highscore for exams",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "score": { "type": "number" },
        "updatedAt": { "type": "object" }
      },
      "required": ["uid", "score"]
    }
  },
  "firestore": {
    "exam_leaderboard/{userId}": {
      "schema": { "$ref": "#/entities/ExamScore" },
      "description": "Exam Leaderboard scores"
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "stories/{storyId}": {
      "schema": { "$ref": "#/entities/Story" },
      "description": "Public stories"
    },
    "stories/{storyId}/chapters/{chapterId}": {
      "schema": { "$ref": "#/entities/Chapter" },
      "description": "Story chapters"
    },
    "chatMessages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Global chat"
    },
    "comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Story/chapter comments"
    },
    "userTasks/{taskId}": {
      "schema": { "$ref": "#/entities/UserTask" },
      "description": "User task tracking"
    },
    "store_stickers/{stickerId}": {
      "schema": { "$ref": "#/entities/AvatarSticker" },
      "description": "Collectible avatar stickers"
    },
    "store_accessories/{accessoryId}": {
      "schema": { "$ref": "#/entities/AvatarAccessory" },
      "description": "Collectible avatar accessories"
    },
    "store_chucu_accessories/{accessoryId}": {
      "schema": { "$ref": "#/entities/AvatarAccessory" },
      "description": "Collectible custom AI-generated avatar accessories for Chucu"
    },
    "notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications"
    },
    "newsFeed/{postId}": {
      "schema": { "$ref": "#/entities/NewsFeedPost" },
      "description": "Global news feed posts uploaded by users"
    },
    "radioTracks/{trackId}": {
      "schema": { "$ref": "#/entities/RadioTrack" },
      "description": "Radio streams list"
    },
    "gacha_banners/{bannerId}": {
      "schema": { "$ref": "#/entities/GachaBanner" },
      "description": "Gacha reward configurations"
    }
  }
}
